MODEL_EDITOR_CHEFE=nvidia/nemotron-3-super-120b-a12b:free
MODEL_CRONISTAS=nvidia/nemotron-3-super-120b-a12b:free

# Investigação (documentos/imagens) — Nano 12B VL multimodal
