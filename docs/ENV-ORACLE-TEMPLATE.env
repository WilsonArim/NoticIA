# ══════════════════════════════════════════════════════════════
# MODELOS POR FUNCAO
# ══════════════════════════════════════════════════════════════
#
# 5 modelos NVIDIA, cada um escolhido pela especializacao:
#
# ┌──────────────────────┬─────────────────────────────────────┬───────────────────────────────────────────┐
# │ Funcao               │ Modelo                              │ Porque este?                              │
# ├──────────────────────┼─────────────────────────────────────┼───────────────────────────────────────────┤
# │ Dispatcher           │ Nano 30B (3B activos)               │ Rapido. Desenhado para routing de agentes │
# │ Fact-Checker         │ Super 120B (12B activos)            │ Maxima precisao em verificacao            │
# │ Escritor             │ Super 120B (12B activos)            │ Melhor escrita PT-PT                      │
# │ Dossie               │ Super 120B (12B activos, 1M ctx)   │ Analise profunda, contexto longo          │
# │ Safety (disinfo)     │ Content Safety 4B                   │ Fine-tuned para detectar propaganda       │
# │ Vision (investigacao)│ Nano 12B VL                         │ Analise de imagens, docs, PDFs            │
# │ Traducao             │ riva-translate 4B                   │ Traduz fontes EN/FR/ES/DE/AR/ZH/RU → PT  │
# │ Auditor              │ Super 120B (12B activos)            │ Double-check rigoroso                     │
# │ Editor-Chefe         │ Super 120B (12B activos)            │ Ultima linha de defesa editorial          │
# │ Cronistas            │ Super 120B (12B activos)            │ Escrita de opiniao com personalidade      │
# └──────────────────────┴─────────────────────────────────────┴───────────────────────────────────────────┘

# --- PIPELINE PRINCIPAL (jobs existentes no scheduler_ollama.py) ---

# Dispatcher — classifica ~2000 eventos/dia, routing para reporters
MODEL_TRIAGEM=nvidia/nemotron-3-nano-30b-a3b

# Fact-Checker — verificacao cruzada, logica, contradicoes
MODEL_FACTCHECKER=nvidia/nemotron-3-super-120b-a12b

# Escritor — artigos PT-PT, piramide invertida, Orwell rules
MODEL_ESCRITOR=nvidia/nemotron-3-super-120b-a12b

# Dossie — contexto profundo, timeline, conexoes entre eventos
MODEL_DOSSIE=nvidia/nemotron-3-super-120b-a12b

# --- MODELOS ESPECIALIZADOS (novos jobs a implementar) ---

# Safety — pre-filtro anti-desinformacao (reporter-desinformacao, fc-justica)
MODEL_SAFETY=nvidia/nemotron-content-safety-reasoning-4b

# Vision — analise de documentos/imagens (reporter-investigacao, fc-forense)
MODEL_VISION=nvidia/nemotron-nano-12b-v2-vl

# Traducao — fontes nao-PT para PT (17 reporters internacionais)
MODEL_TRANSLATE=nvidia/riva-translate-4b-instruct-v1_1

# --- CAMADA EDITORIAL (novos jobs a implementar) ---

# Auditor, Editor-Chefe, Cronistas — todos usam o Super
MODEL_AUDITOR=nvidia/nemotron-3-super-120b-a12b
MODEL_EDITOR_CHEFE=nvidia/nemotron-3-super-120b-a12b
MODEL_CRONISTAS=nvidia/nemotron-3-super-120b-a12b
